# Copy this file to `.env` and fill in your key. `.env` is gitignored.
#
#   cp .env.example .env
#
# Get a free key at https://elevenlabs.io/app/settings/api-keys

# Required: your ElevenLabs API key.
ELEVENLABS_API_KEY=your-api-key-here

# Optional: default voice used when --voice is not passed.
# `eleven-tts voices --search "Taiwan"` only searches voices already in YOUR
# account, not the shared library. A Taiwanese-Mandarin accent requires a
# paid ElevenLabs plan even after adding a shared-library voice to your
# account — see README "Known limitation" for the full story.
# (falls back to "George" / JBFqnCBsd6RMkjVDRZzb if unset)
ELEVENLABS_VOICE_ID=

# Optional overrides (sensible defaults are applied if omitted).
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Optional tuning for retry / concurrency / timeout.
ELEVENLABS_MAX_RETRIES=4
ELEVENLABS_MAX_CONCURRENCY=3
ELEVENLABS_REQUEST_TIMEOUT=30
